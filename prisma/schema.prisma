// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  STAFF
  ACCOUNTING
  CLIENT
}

enum JobStatus {
  NEW
  PROCESS
  PENDING
  REVISION
  DONE
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvoiceStatus {
  UNPAID
  PARTIAL
  PAID
}

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  email         String         @unique
  passwordHash  String
  fullName      String
  role          Role           @default(STAFF)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  jobs          Job[]          @relation("StaffJobs")
  jobProgress   JobProgress[]
  reminders     Reminder[]
  notifications Notification[]
  activityLogs  ActivityLog[]
  attachments   Attachment[]
}

model Client {
  id          String   @id @default(cuid())
  name        String
  email       String?
  phone       String?
  address     String?  @db.Text
  npwp        String?
  birthday    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  jobs        Job[]
}

model Job {
  id           String        @id @default(cuid())
  trackingCode String        @unique
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  staffId      String?
  staff        User?         @relation("StaffJobs", fields: [staffId], references: [id])
  title        String
  type         String
  status       JobStatus     @default(NEW)
  priority     JobPriority   @default(MEDIUM)
  deadline     DateTime?
  notes        String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  progress     JobProgress[]
  invoices     Invoice[]
  taxes        Tax[]
  attachments  Attachment[]
}

model JobProgress {
  id           String    @id @default(cuid())
  jobId        String
  job          Job       @relation(fields: [jobId], references: [id])
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  statusBefore JobStatus
  statusAfter  JobStatus
  percentage   Int       @default(0)
  notes        String?   @db.Text
  createdAt    DateTime  @default(now())
}

model Attachment {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  fileName  String
  filePath  String
  fileType  String
  createdAt DateTime @default(now())
}

model Invoice {
  id            String        @id @default(cuid())
  jobId         String
  job           Job           @relation(fields: [jobId], references: [id])
  invoiceNumber String        @unique
  totalAmount   Decimal       @db.Decimal(15, 2)
  taxAmount     Decimal       @db.Decimal(15, 2) @default(0)
  status        InvoiceStatus @default(UNPAID)
  dueDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  payments      Payment[]
}

model Payment {
  id            String   @id @default(cuid())
  invoiceId     String
  invoice       Invoice  @relation(fields: [invoiceId], references: [id])
  amount        Decimal  @db.Decimal(15, 2)
  paymentMethod String
  paymentDate   DateTime @default(now())
  notes         String?  @db.Text
  createdAt     DateTime @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  category    String
  amount      Decimal  @db.Decimal(15, 2)
  description String?  @db.Text
  expenseDate DateTime @default(now())
  createdAt   DateTime @default(now())
}

model Tax {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id])
  type      String   // Titipan Pajak, SPS, etc
  amount    Decimal  @db.Decimal(15, 2)
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
}

model Reminder {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  title       String
  description String?   @db.Text
  remindAt    DateTime
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String   @db.Text
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  activity  String
  details   String?  @db.Text
  ipAddress String?
  device    String?
  createdAt DateTime @default(now())
}
